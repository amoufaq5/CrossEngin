{
  "name": "crossengin",
  "version": "0.0.0",
  "description": "CrossEngin — AI-native application platform",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/amoufaq5/CrossEngin"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "start": "node apps/operate-server/dist/bin/operate-server.js --pack ${CROSSENGIN_PACK:-erp-retail} --store ${CROSSENGIN_STORE:-pg} --port ${PORT:-8080} --scheme https --api-key ${CROSSENGIN_API_KEY:-devkey:retail_admin:00000000-0000-4000-8000-000000000001}",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
