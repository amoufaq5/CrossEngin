{
  "name": "crossengin",
  "version": "0.0.0",
  "description": "CrossEngin — AI-native application platform",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/amoufaq5/CrossEngin"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "coverage": "pnpm build && pnpm -r --filter \"!@crossengin/config\" exec vitest run --coverage",
    "typecheck": "turbo run typecheck",
    "typecheck:tests": "pnpm build && tsc -p tsconfig.typecheck-tests.json",
    "dev": "turbo run dev",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
