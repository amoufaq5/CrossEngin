{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "deploy/Dockerfile"
  },
  "deploy": {
    "startCommand": "node apps/operate-server/dist/bin/operate-server.js --pack erp-retail --store pg --port $PORT --scheme https --api-key $CROSSENGIN_API_KEY",
    "restartPolicyType": "ON_FAILURE"
  }
}
