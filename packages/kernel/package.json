{
  "name": "@crossengin/kernel",
  "version": "0.0.0",
  "private": true,
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tenancy": {
      "types": "./dist/tenancy/index.d.ts",
      "import": "./dist/tenancy/index.js"
    },
    "./ddl": {
      "types": "./dist/ddl/index.d.ts",
      "import": "./dist/ddl/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest/index.d.ts",
      "import": "./dist/manifest/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js"
    },
    "./bootstrap": {
      "types": "./dist/bootstrap/index.d.ts",
      "import": "./dist/bootstrap/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@crossengin/auth": "workspace:*",
    "@crossengin/files": "workspace:*",
    "@crossengin/i18n": "workspace:*",
    "@crossengin/integrations": "workspace:*",
    "@crossengin/jobs": "workspace:*",
    "@crossengin/reporting": "workspace:*",
    "@crossengin/search": "workspace:*",
    "@crossengin/types": "workspace:*",
    "@crossengin/views": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@crossengin/config": "workspace:*",
    "@crossengin/testing": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
